# CRA reads this at build/start time. Copy to .env.development.local (gitignored).

# Backend (FastAPI). In development this defaults to http://localhost:8000 if unset.
REACT_APP_BACKEND_URL=http://localhost:8000

# Optional overrides — project id/dataset usually match sanity.js defaults
# REACT_APP_SANITY_PROJECT_ID=
# REACT_APP_SANITY_DATASET=production
