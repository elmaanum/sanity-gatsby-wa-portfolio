# Copy to .env and fill in values. Do not commit .env.
#
# Resend (https://resend.com) — contact form email
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev
RECIPIENT_EMAIL=info@whittenassociates.com

# Sanity (optional overrides; defaults match server.py)
SANITY_PROJECT_ID=6raq5w4t
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
# Only if your dataset is private / you need draft content
SANITY_READ_TOKEN=

# Comma-separated origins for CORS (no spaces). Use * only for local experiments.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
